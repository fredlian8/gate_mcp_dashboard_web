#是否开启 MACD 预警后台推送线程
MACD_PREALERT_PUSH_ENABLED=1

#是否开启 MACD 监控后台推送线程
MACD_MONITOR_PUSH_ENABLED=1

#是否开启新闻后台线程（抓取/分析/合并推送）
NEWS_AUTO_PUSH_ENABLED=1

#合并推送“最近窗口”的新闻时间范围（秒）
NEWS_AUTO_PUSH_WINDOW_SEC=1800

#开启强信号 TG 推送后台线程
SIGNAL_PUSH_ENABLED=1

#推送扫描间隔（秒）
SIGNAL_PUSH_INTERVAL_SEC=600

#强信号阈值（abs(score) >= 该值 才推）
SIGNAL_PUSH_SCORE_STRONG=6
#同一个币推送冷却时间（秒），冷却期内不会重复推
SIGNAL_PUSH_COOLDOWN_SEC=900

#是否允许“同方向强信号”重复推送
SIGNAL_PUSH_REPEAT_SAME_DIRECTION=1

#推送时使用的 K 线时间框架（影响 pct/OI/MACD/RSI/量能等口径）
SIGNAL_PUSH_K_TF=1h

#用三周期推送
TRI_SIGNAL_PUSH_ENABLED=1

#并发线程池大小（默认 3）
TRI_SIGNAL_MAX_WORKERS=3
TRI_SIGNAL_CONTRACTS=BTC,ETH,SOL,BNB,DOGE,HYPE,QQQX,SPYX,XBR,TSLAX,CRCLX,AAPLX,NVDAX,MSTRX,INTC,GOOGLX,TSM,ORCL,MSFT,XTI,NGU,XAUT,XAGU,XPT,XCU,XPD,XAL,XPB,XNI,PLTRX,LITE,COINX,MUU,SNDK,JDON,SPACEX,AMZNX,VCX,MRVL,HOODX,COHR,AMD,EWY,ASML,ARM,METAX,SLVON,IBM,CSCO,TSM,PAYP,AVGO,LMT,KO


GATE_MCP_X_API_KEY=MCP_AK_8W2N7Q

#启动策略A推送循环
MASTER_A_PUSH_ENABLED=1
MASTER_A_PUSH_INTERVAL_SEC=300
MASTER_A_PUSH_COOLDOWN_SEC=1800
#启动策略B推送循环
MASTER_B_PUSH_ENABLED=1
MASTER_B_PUSH_INTERVAL_SEC=300
MASTER_B_PUSH_COOLDOWN_SEC=1800